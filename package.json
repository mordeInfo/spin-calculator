{
  "name": "spin-ev-calculator",
  "version": "1.0.6",
  "description": "Spin EV Calculator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.spin.calculator",
    "productName": "Spin EV Calculator",
    "publish": {
      "provider": "github",
      "owner": "mordeInfo",
      "repo": "spin-calculator",
      "private": true
    },
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
